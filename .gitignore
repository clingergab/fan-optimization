# Project data — large/binary artefacts NOT source-controlled.
# NOTE: `data/*` (one-star), NOT `data/` — the latter blanket-excludes the
# directory and silently kills every negation below; per git docs:
# "It is not possible to re-include a file if a parent directory of that
# file is excluded."
data/*
!data/.gitkeep

# Phase-0 spike PASS markers + small result JSONs ARE source-controlled
# (they are the audit trail showing gates passed). The Drive caches +
# heavy artefacts (SU2 history.csv, restart files, mesh files) in the
# same directories remain ignored — only the sentinels and the tiny
# JSON summaries are tracked.
!data/spike_0_*/
data/spike_0_*/*
!data/spike_0_*/PASS
!data/spike_0_*/sub_*.PASS
!data/spike_0_*/results.json
!data/spike_0_*/sub_*_result.json
!data/spike_0_*/deferral.json

# Phase 3 correlation sweep — track only the tiny result JSON; the per-design
# SU2 dumps (history/restart/vtu) stay ignored.
!data/phase3_sweep/
data/phase3_sweep/*
!data/phase3_sweep/correlation.json

# Local Drive sync
gdrive/
*.bak

# Per-run Fusion spike params — params.example.json is the canonical schema;
# params.json carries the operator's actual run values and is local-only.
configs/fusion/params.json

# SU2 outputs that may land in repo root from quick experiments
history*.csv
flow.vtu
restart_flow.dat
surface_flow.vtu

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
