% SU2 config template — wind-tunnel-frame NACA 0012 oscillating-airfoil
% benchmark. Phase-5 prep deliverable (NOT a V1 gate).
%
% Source-of-truth: docs/plan_R11.md §Phase 0 Spike 0.6c (lines 1839-1844)
% V1 scope:        docs/phase_logs/spike_0_6c.md  ("V1 decision — Spike
%                  0.6c.2 deferred to Phase 5 (2026-05-XX)")
%
% Why this template exists (and what changed on 2026-05-XX):
%
%   The 2026-05-XX regime diagnostic
%   (`scripts/diagnose_su2_pitching_regime.py`) confirmed that running
%   this benchmark with the production Tier-1 numerics (MACH = 1e-9 +
%   FREESTREAM_PRESS_EQ_ONE) produces moving-body-in-still-air
%   added-mass / quadratic-drag forces — CL oscillates at 2× the
%   pitching frequency with a non-physical mean bias. Those numerics
%   are correct for fan3d_unsteady.cfg.j2 (where the fan really IS
%   moving through still air) but they make the cfg unvalidatable
%   against any published wind-tunnel reference, since wind-tunnel
%   data is collected in the conventional frame (airfoil pitches about
%   a fixed point, freestream flows past it).
%
%   This template is the wind-tunnel-frame version: the freestream is
%   ON (MACH > 0, non-trivial Reynolds via REYNOLDS_NUMBER /
%   REYNOLDS_LENGTH), and the airfoil pitches about its quarter chord
%   in place. CL/CD should behave like the published references at the
%   matched (k_reduced, Re) point.
%
%   This cfg has NO V1 consumer. It exists so Phase 5's cross-solver
%   gate (SU2 vs PyFR p=3 on G4 GPU — Round-9 HIGH-11 lock) starts
%   from a conceptually sound benchmark cfg instead of repeating the
%   2026-05 diagnostic loop.
%
% Reference case (default — operator may substitute another low-Re
% pitching case as long as both reference data and rationale are cited):
%   NACA 0012, pitching about quarter-chord
%   k_reduced ≈ 0.55  (band: 0.5 - 0.6)
%   Re        ≈ 40000 (band: 30000 - 50000)
%   amplitude ≈ ±10°
%   5 cycles total; discard cycle 1; integrate cycles 2-5
%
% Operator-supplied template variables (rendered via
% `fanopt.cfd.configs.render_benchmark_cfg`):
%   {{ mesh_filename }}        - .su2 mesh path (NACA 0012 O-grid / C-grid)
%   {{ marker_airfoil }}       - physical-group name on airfoil surface
%   {{ marker_farfield }}      - physical-group name on outer boundary
%   {{ mach_number }}          - MACH (default 0.05 — low enough to call
%                                effectively incompressible; high enough
%                                that the compressible solver is well
%                                conditioned with LOW_MACH_PREC = YES)
%   {{ reynolds_number }}      - target Re (within [30000, 50000])
%   {{ reynolds_length }}      - reference chord length (m)
%   {{ pitching_omega_y }}     - angular frequency (rad/s) for the target
%                                k_reduced; sign follows C11 convention
%   {{ pitching_ampl_y }}      - pitch amplitude (rad); default ~0.1745
%                                (= 10°)
%   {{ motion_origin_x }}      - pitching axis x-location (quarter-chord
%                                = 0.25 * c)
%   {{ time_step }}            - dt = T/200 by spec
%   {{ max_time }}             - 5 * T (5 full cycles)
%   {{ time_iter }}            - 5 * 200 = 1000 outer time steps
%
% NOT a Tier-1 lock-equivalence template — the MACH lock (Round-9
% HIGH-12 / C12) intentionally does NOT apply here. The Tier-1
% production cfg `fan3d_unsteady.cfg.j2` is the source of truth for the
% MACH = 1e-9 unsteady lock.
%
% --------------------------------------------------------------------------

SOLVER= NAVIER_STOKES
KIND_TURB_MODEL= NONE
MATH_PROBLEM= DIRECT
RESTART_SOL= NO

% --- wind-tunnel-frame freestream (Phase-5-prep, NOT the Tier-1 lock) ---
MACH_NUMBER= {{ mach_number }}
FREESTREAM_TEMPERATURE= {{ freestream_temperature | default(300.0) }}
FREESTREAM_PRESSURE= {{ freestream_pressure | default(101325.0) }}

REYNOLDS_NUMBER= {{ reynolds_number }}
REYNOLDS_LENGTH= {{ reynolds_length }}

% --- low-Mach preconditioning (MACH ~ 0.05 needs this for conditioning) ---
LOW_MACH_PREC= YES
MIN_ROE_TURKEL_PREC= 0.01
MAX_ROE_TURKEL_PREC= 0.2

% --- dual-time-stepping for the 5-cycle pitching run ---
TIME_DOMAIN= YES
TIME_MARCHING= DUAL_TIME_STEPPING-2ND_ORDER
TIME_STEP= {{ time_step }}
MAX_TIME= {{ max_time }}
TIME_ITER= {{ time_iter }}
INNER_ITER= {{ inner_iter | default(100) }}

% --- pitching about the quarter-chord ---
GRID_MOVEMENT= RIGID_MOTION
MOTION_ORIGIN= {{ motion_origin_x }} 0.0 0.0
PITCHING_OMEGA= 0.0 {{ pitching_omega_y }} 0.0
PITCHING_AMPL=  0.0 {{ pitching_ampl_y }} 0.0

% --- boundary conditions ---
MARKER_HEATFLUX= ( {{ marker_airfoil }}, 0.0 )
MARKER_FAR= ( {{ marker_farfield }} )
MARKER_MONITORING= ( {{ marker_airfoil }} )
MARKER_PLOTTING= ( {{ marker_airfoil }} )

% --- output ---
MESH_FILENAME= {{ mesh_filename }}
MESH_FORMAT= SU2
TABULAR_FORMAT= CSV
CONV_FILENAME= history
SURFACE_FILENAME= surface_flow
VOLUME_FILENAME= flow
OUTPUT_FILES= ( RESTART, PARAVIEW, SURFACE_CSV )
HISTORY_OUTPUT= ( ITER, RMS_RES, AERO_COEFF, FLOW_COEFF )

% --- numerics ---
NUM_METHOD_GRAD= WEIGHTED_LEAST_SQUARES
CFL_NUMBER= {{ cfl_number | default(1.0) }}
CONV_NUM_METHOD_FLOW= ROE
MUSCL_FLOW= YES
SLOPE_LIMITER_FLOW= VENKATAKRISHNAN
TIME_DISCRE_FLOW= EULER_IMPLICIT
LINEAR_SOLVER= FGMRES
LINEAR_SOLVER_PREC= LU_SGS
LINEAR_SOLVER_ERROR= 1E-6
LINEAR_SOLVER_ITER= 25

% --- convergence ---
CONV_RESIDUAL_MINVAL= -8
CONV_STARTITER= 10
SCREEN_WRT_FREQ_INNER= 10
