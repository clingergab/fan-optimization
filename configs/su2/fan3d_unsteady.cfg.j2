% SU2 config template — Tier 1 (3D unsteady, full deployed fan; HIGH-12 freestream lock).
% Renderer: src/fanopt/cfd/configs.py — render_unsteady_cfg().
% Source-of-truth: docs/plan_R11.md §9.4.1 CROSS_TIER + TIER_SPECIFIC[1].
%
% This is the production Tier-1 cfg. Spike 0.6c.2 validates these same numerics
% on a published NACA 0012 reference; spike_0_6c.1 validates THIS template
% parses + runs ≥1 outer step on a probe mesh.
%
% Operator-supplied template variables (rendered via fanopt.cfd.configs):
%   {{ mesh_filename }}        - .su2 mesh path (10-blade deployed fan)
%   {{ marker_fan }}           - physical-group name(s) covering all blade surfaces
%   {{ marker_farfield }}      - physical-group name on the outer boundary
%   {{ reynolds_number }}      - Re_global = 37000 per §3.2.3 (locked)
%   {{ reynolds_length }}      - L_wrist_to_tip = 0.25 m (locked)
%   {{ pitching_omega_y }}     - ω_SHM = -12.5664 rad/s (C11 sign lock — NEGATIVE y)
%   {{ pitching_ampl_y }}      - θ_max = +0.6981 rad (40°)
%   {{ motion_origin_x }}      - wrist-grip point at world origin = 0.0
%   {{ motion_origin_y }}      - 0.0
%   {{ motion_origin_z }}      - 0.0
%   {{ time_step }}            - dt = T/200 = 2.5 ms per §0 + §3.2.3
%   {{ max_time }}             - 5 * T = 2.5 s (5 full cycles)
%   {{ time_iter }}            - 5 * 200 = 1000 outer time steps
%
% Tier-1 lock invariants (Round-9 HIGH-12 / C12 — enforced by
% tests/test_cfd/test_unsteady_freestream_consistency.py):
%   1. MACH_NUMBER = 1e-9                          (NOT 0.0064 — that's steady)
%   2. FREESTREAM_OPTION = FREESTREAM_VELOCITY     (primary path, deprecated)
%      OR REF_DIMENSIONALIZATION = FREESTREAM_PRESS_EQ_ONE (fallback — used)
%   3. LOW_MACH_PREC = YES                         (compressible low-Mach prec)
%   4. TIME_MARCHING = DUAL_TIME_STEPPING-2ND_ORDER
%   5. GRID_MOVEMENT = RIGID_MOTION                (fan rotates about wrist axis)
%   6. PITCHING_OMEGA y-component < 0              (C11 right-hand-rule lock)
%
% Note on the primary-vs-fallback choice: SU2 v8.0.1 rejects the
% `FREESTREAM_OPTION = FREESTREAM_VELOCITY` directive at parse time
% ("invalid option value FREESTREAM_VELOCITY. Did you mean DENSITY_FS,
% TEMPERATURE_FS?"), verified empirically by Spike 0.6c.1 on Colab Pro
% CPU. The template therefore ships the fallback path
% (`REF_DIMENSIONALIZATION = FREESTREAM_PRESS_EQ_ONE` + reference state
% via `FREESTREAM_TEMPERATURE` / `FREESTREAM_PRESSURE`) which is
% equivalent for compressible-zero-flow numerics. If a future SU2 build
% restores the primary syntax, flip back via the renderer.
%
% --------------------------------------------------------------------------

SOLVER= NAVIER_STOKES
KIND_TURB_MODEL= NONE
MATH_PROBLEM= DIRECT
RESTART_SOL= NO

% --- Round-9 HIGH-12 / C12 unsteady freestream lock (SU2 v8.0.1 fallback) ---
MACH_NUMBER= 1e-9
REF_DIMENSIONALIZATION= FREESTREAM_PRESS_EQ_ONE
FREESTREAM_TEMPERATURE= 300.0
FREESTREAM_PRESSURE= 101325.0

REYNOLDS_NUMBER= {{ reynolds_number }}
REYNOLDS_LENGTH= {{ reynolds_length }}

% --- low-Mach preconditioning (Tier-1 lock) ---
LOW_MACH_PREC= YES
MIN_ROE_TURKEL_PREC= 0.01
MAX_ROE_TURKEL_PREC= 0.2

% --- dual-time-stepping over 5 cycles ---
TIME_DOMAIN= YES
TIME_MARCHING= DUAL_TIME_STEPPING-2ND_ORDER
TIME_STEP= {{ time_step }}
MAX_TIME= {{ max_time }}
TIME_ITER= {{ time_iter }}
INNER_ITER= {{ inner_iter | default(100) }}

% --- pitching about the wrist axis (+y) at the wrist-grip point ---
% C11 sign lock: PITCHING_OMEGA y-component is NEGATIVE (right-hand-rule on
% productive stroke); the locked value is -12.5664 rad/s (SU2 PITCHING_OMEGA
% is rad/s). PITCHING_AMPL y is POSITIVE 40.0 — SU2 PITCHING_AMPL is in
% DEGREES (the renderer converts the locked +0.6981 rad = 40° to degrees;
% emitting radians would pitch the fan ~57x too little).
GRID_MOVEMENT= RIGID_MOTION
MOTION_ORIGIN= {{ motion_origin_x | default(0.0) }} {{ motion_origin_y | default(0.0) }} {{ motion_origin_z | default(0.0) }}
PITCHING_OMEGA= 0.0 {{ pitching_omega_y }} 0.0
PITCHING_AMPL=  0.0 {{ pitching_ampl_y }} 0.0

% --- boundary conditions ---
MARKER_HEATFLUX= ( {{ marker_fan }}, 0.0 )
MARKER_FAR= ( {{ marker_farfield }} )
MARKER_MONITORING= ( {{ marker_fan }} )
MARKER_PLOTTING= ( {{ marker_fan }} )

% --- output ---
MESH_FILENAME= {{ mesh_filename }}
MESH_FORMAT= SU2
TABULAR_FORMAT= CSV
CONV_FILENAME= history
SURFACE_FILENAME= surface_flow
VOLUME_FILENAME= flow
OUTPUT_FILES= {{ output_files }}
{% if output_wrt_freq is not none %}OUTPUT_WRT_FREQ= {{ output_wrt_freq }}
{% endif %}
HISTORY_OUTPUT= ( ITER, RMS_RES, AERO_COEFF, FLOW_COEFF )

% --- numerics ---
NUM_METHOD_GRAD= WEIGHTED_LEAST_SQUARES
CFL_NUMBER= {{ cfl_number | default(1.0) }}
CONV_NUM_METHOD_FLOW= ROE
MUSCL_FLOW= YES
SLOPE_LIMITER_FLOW= VENKATAKRISHNAN
TIME_DISCRE_FLOW= EULER_IMPLICIT
LINEAR_SOLVER= FGMRES
LINEAR_SOLVER_PREC= LU_SGS
LINEAR_SOLVER_ERROR= 1E-6
LINEAR_SOLVER_ITER= 25

% --- convergence ---
CONV_RESIDUAL_MINVAL= -8
CONV_STARTITER= 10
SCREEN_WRT_FREQ_INNER= 10
